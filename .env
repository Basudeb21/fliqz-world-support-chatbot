APP_NAME=Fliqz AI Support
APP_ENV=development
DEBUG=True

HOST=0.0.0.0
PORT=8000


MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=fliqz_ai


REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

REDIS_CHAT_STREAM=chat_stream
REDIS_CONSUMER_GROUP=chat_workers
REDIS_CONSUMER_NAME=worker_1



CHROMA_DB_PATH=./data/chroma
CHROMA_COLLECTION=support_docs



OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
OLLAMA_EMBED_MODEL=nomic-embed-text


SHORT_TERM_MEMORY_LIMIT=10
MEMORY_SUMMARY_THRESHOLD=20


RAG_TOP_K=5

RAG_SCORE_THRESHOLD=0.7
CHUNK_SIZE=500
CHUNK_OVERLAP=50


MAX_INPUT_TOKENS=4096
MAX_OUTPUT_TOKENS=512


API_SECRET_KEY=change_this_secret_key

JWT_ALGORITHM=HS256

ACCESS_TOKEN_EXPIRE_MINUTES=10080



LOG_LEVEL=INFO